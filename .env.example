# ── Base de datos PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/estetica_db
# Supabase pooler: postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Auth admin (JWT) ────────────────────────────────────────────────────────
# Generá una clave aleatoria segura: openssl rand -base64 32
ADMIN_JWT_SECRET=cambiar-por-clave-secreta-larga-y-aleatoria

# ── MercadoPago ─────────────────────────────────────────────────────────────
# Obtené tu Access Token en: https://www.mercadopago.com.ar/developers/panel
# Usar el token de TEST para desarrollo, el de PRODUCCIÓN para live
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# ── URL pública de la app (para back_urls de MercadoPago) ───────────────────
# En local: http://localhost:3000
# En producción: https://tudominio.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Obtené tu API Key en: https://resend.com (free: 3000 emails/mes)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Reservas <noreply@tudominio.com>

# ── Cron Jobs (Vercel) ───────────────────────────────────────────────────────
# Secret para proteger el endpoint de recordatorios
CRON_SECRET=cron-secret-aleatorio-largo

# ── Super Admin ──────────────────────────────────────────────────────────────
# Accedé con: /superadmin?secret=TU_SECRET
SUPERADMIN_SECRET=superadmin-secret-muy-seguro
